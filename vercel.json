{
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "installCommand": "pnpm install",
  "framework": "other",
  "outputDirectory": "dist",
  "public": false,
  "rewrites": [
    {
      "source": "/api/trpc/:path*",
      "destination": "/api/trpc/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "DATABASE_URL": {
      "description": "MySQL database connection string",
      "required": true
    },
    "JWT_SECRET": {
      "description": "Secret key for JWT token signing",
      "required": true
    },
    "VITE_APP_ID": {
      "description": "Manus OAuth application ID",
      "required": true
    },
    "OAUTH_SERVER_URL": {
      "description": "Manus OAuth server URL",
      "required": true
    },
    "VITE_OAUTH_PORTAL_URL": {
      "description": "Manus OAuth portal URL",
      "required": true
    },
    "OWNER_OPEN_ID": {
      "description": "Owner's Manus OpenID",
      "required": true
    },
    "OWNER_NAME": {
      "description": "Owner's name",
      "required": true
    },
    "BUILT_IN_FORGE_API_URL": {
      "description": "Manus built-in API URL",
      "required": true
    },
    "BUILT_IN_FORGE_API_KEY": {
      "description": "Manus built-in API key",
      "required": true
    },
    "VITE_FRONTEND_FORGE_API_URL": {
      "description": "Frontend API URL",
      "required": true
    },
    "VITE_FRONTEND_FORGE_API_KEY": {
      "description": "Frontend API key",
      "required": true
    },
    "VITE_ANALYTICS_ENDPOINT": {
      "description": "Analytics endpoint (optional)",
      "required": false
    },
    "VITE_ANALYTICS_WEBSITE_ID": {
      "description": "Analytics website ID (optional)",
      "required": false
    }
  },
  "functions": {
    "server/_core/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  }
}
